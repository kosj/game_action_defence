; Engine configuration file.
; Godot 4.x — Action Defence (Mobile WebGL)
; 에디터에서 한 번 열면 uid 등이 자동 채워집니다.

config_version=5

[application]

config/name="Action Defence"
run/main_scene="res://scenes/TitleScreen.tscn"
config/features=PackedStringArray("4.1", "GL Compatibility")

; 최초 구동 시 고도 엔진 로고(부팅 스플래시) 이미지를 숨긴다 — 배경색만 잠깐 보이고 바로 게임으로.
boot_splash/show_image=false
boot_splash/bg_color=Color(0, 0, 0, 1)

[autoload]

Events="*res://scripts/Events.gd"
Pool="*res://scripts/Pool.gd"
SoundManager="*res://scripts/SoundManager.gd"
SaveManager="*res://scripts/SaveManager.gd"
MetaManager="*res://scripts/MetaManager.gd"
RankingManager="*res://scripts/RankingManager.gd"
AdManager="*res://scripts/AdManager.gd"
Locale="*res://scripts/Locale.gd"
UITheme="*res://scripts/UITheme.gd"

[gui]

; 전역 기본 폰트를 엔진 레벨에서 CJK 폰트로 지정 — 씬 로드 이전에 적용되므로 웹 빌드에서도
; 모든 라벨/버튼에 한글·일본어가 정상 렌더된다. (런타임 root.theme 의 default_font 는 웹에서
; 적용이 누락돼, 폰트 오버라이드를 쓰지 않은 일반 라벨/버튼의 CJK 글리프가 깨지던 문제 해결.)
theme/custom_font="res://assets/fonts/NotoSansCJK-Subset.otf"

[display]

; 모바일 세로 화면 기준 (필요시 가로로 바꾸세요)
window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[input_devices]

; 데스크톱(에디터/브라우저)에서 마우스로 터치를 흉내 → 조이스틱 테스트 가능
pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true

[internationalization]

; 한글(CJK) 렌더링을 위해 FreeType/HarfBuzz 텍스트 서버 사용
; TextServerFallback은 CJK 글리프를 지원하지 않음
rendering/text_driver="ICU / HarfBuzz / FreeType"

[rendering]

; WebGL/모바일 호환을 위해 반드시 Compatibility 렌더러 사용
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true

[layer_names]

2d_physics/layer_1="player"
2d_physics/layer_2="zombies"
2d_physics/layer_3="bullets"
2d_physics/layer_4="gold"
